server {
    server_name 34.38.183.107 team5.ua-ppdb.com;

    # Frontend (Vite build output)
    root /home/app/projectdatabases/frontend/dist;
    index index.html;

    # API -> Flask (Gunicorn via unix socket)
    location /api/ {
        include proxy_params;
        proxy_pass http://unix:/home/app/projectdatabases/backend/webapp.sock:;
    }

    # SPA fallback
    location / {
        try_files $uri /index.html;
    }

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/team5.ua-ppdb.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/team5.ua-ppdb.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}
server {
    if ($host = team5.ua-ppdb.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name 34.38.183.107 team5.ua-ppdb.com;
    return 404; # managed by Certbot


}